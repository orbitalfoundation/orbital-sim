{
  "slug": "/_schema/taxonomy",
  "components": {
    "meta": {
      "label": "taxonomy",
      "content": "Biological classification for organisms. Use alongside `party` (kind=animal) and optionally `habitat`.",
      "tags": ["schema", "component"]
    },
    "schema": {
      "componentName": "taxonomy",
      "fields": {
        "common_name":     { "type": "string", "description": "Vernacular name (e.g. 'green moray eel')" },
        "scientific_name": { "type": "string", "description": "Binomial nomenclature (genus species)" },
        "kingdom":         { "type": "string", "description": "Taxonomic kingdom" },
        "phylum":          { "type": "string", "description": "Taxonomic phylum" },
        "class":           { "type": "string", "description": "Taxonomic class" },
        "order":           { "type": "string", "description": "Taxonomic order" },
        "family":          { "type": "string", "description": "Taxonomic family" },
        "genus":           { "type": "string", "description": "Taxonomic genus" },
        "species":         { "type": "string", "description": "Specific epithet" }
      }
    }
  }
}
