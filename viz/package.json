{
  "name": "@orbital/viz",
  "version": "0.1.0",
  "description": "Framework-agnostic visualization utilities for geospatial and data-rich applications — globe, charts, map layers, flow diagrams.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "keywords": ["visualization", "globe", "cesium", "3d-tiles", "charts", "geospatial", "three.js"],
  "exports": {
    ".": {
      "import": "./dist/orbital-viz.js",
      "default": "./dist/orbital-viz.js"
    },
    "./globe": {
      "import": "./dist/globe.js",
      "default": "./dist/globe.js"
    },
    "./chart": {
      "import": "./dist/chart.js",
      "default": "./dist/chart.js"
    }
  },
  "main": "./dist/orbital-viz.js",
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "vite build",
    "dev":   "vite build --watch"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "three": { "optional": false }
  },
  "dependencies": {
    "3d-tiles-renderer": "^0.3.42"
  },
  "devDependencies": {
    "three": "^0.165.0",
    "vite": "^6.0.0"
  }
}
