# Dependencies
node_modules/
vendor/
.venv/
env/

# Build outputs and binaries
dist/
build/
bin/
obj/
.next/
.nuxt/
out/
public/assets/viz/        # built viz bundle (regenerated by npm run build:viz)
*.exe
*.dll
*.so

# Git
.git/

# --- Large runtime data caches (the important ones) ---
# public/.data is the gitignored data cache — GEBCO tiles (~7GB), the 18MB
# raster, geojson, sqlite. All fetched/generated at runtime; never read by hand.
public/.data/
.data/
public/_cached_data/

# Binary media — not useful to read as text
*.mp4
*.mov
*.png
*.jpg
*.jpeg
*.webp
*.zip
*.tar.gz
*.gz
*.pdf
*.tif
*.tiff
*.i16

# Databases
*.sqlite
*.db
*.db-wal
*.db-shm

# Logs
*.log
