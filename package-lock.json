{
  "name": "simulate",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "workspaces": [
        "packages/bus",
        "packages/topo",
        "packages/utils",
        "packages/volume"
      ]
    },
    "node_modules/@orbital/bus": {
      "resolved": "packages/bus",
      "link": true
    },
    "node_modules/@orbital/topo": {
      "resolved": "packages/topo",
      "link": true
    },
    "node_modules/@orbital/utils": {
      "resolved": "packages/utils",
      "link": true
    },
    "node_modules/@orbital/volume": {
      "resolved": "packages/volume",
      "link": true
    },
    "packages/bus": {
      "name": "@orbital/bus",
      "version": "2.0.0",
      "dependencies": {
        "@orbital/utils": "file:../utils"
      },
      "bin": {
        "bus": "run.js"
      }
    },
    "packages/topo": {
      "name": "@orbital/topo",
      "version": "0.0.0",
      "dependencies": {
        "@orbital/utils": "file:../utils"
      }
    },
    "packages/utils": {
      "name": "@orbital/utils",
      "version": "2.0.0"
    },
    "packages/volume": {
      "name": "@orbital/volume",
      "version": "1.0.0",
      "dependencies": {
        "@orbital/bus": "file:../bus"
      }
    }
  }
}
