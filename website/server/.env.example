# Copy this to .env and fill in real values.
# Never commit .env — it is gitignored.

# Cesium Ion — satellite imagery tiles for the globe visualization.
# Register at https://cesium.com/ (free tier available).
# Without this the globe falls back to a plain Earth texture.
CESIUM_KEY=your-cesium-ion-token

# ACLED — Armed Conflict Location and Event Data (conflict events with lat/lon).
# Register at https://acleddata.com/ for a free research API key.
# Without these the acled agent will start but serve an empty dataset.
ACLED_KEY=your-acled-api-key
ACLED_EMAIL=your-registration-email@example.com

# Web3Auth server-side secret for verifying idTokens.
# Obtain from the Web3Auth dashboard under your project's "Server-side Verification" settings.
WEB3AUTH_SECRET=your-web3auth-client-secret-here

# TLS certificate paths (relative to the repo root, or absolute).
# For local dev: generate with mkcert (https://github.com/FiloSottile/mkcert):
#   mkcert orbital.local
#   mv orbital.local.pem orbital.local-key.pem website/server/
# For production: use a real cert (e.g. Let's Encrypt via certbot).
# If both are omitted the server starts on plain HTTP.
TLS_CERT=website/server/orbital.local.pem
TLS_KEY=website/server/orbital.local-key.pem
