# typical nodejs ignores
node_modules
node_packages
.env
.DS_Store
**/.DS_Store
dist/
**/dist
.vscode
.idea
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
runs

# TLS certs — injected via env vars or secrets at runtime, not baked in
website/server/*.pem

# this data is too heavy to put into git - see scripts/fetch-data.mjs
public/*/*/.data/
.data
public/.data

# simulation output — runtime artifacts, regenerate with node packages/bus/run.js
**/output/

# viz build output — regenerate with npm run build:viz
public/assets/viz/

# local data cache — hosted in orbital-data repo, fetched by agents on first run
public/_cached_data/

# lets not share this - mostly local claude config
.claude/
